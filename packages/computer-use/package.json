{
  "name": "@ai-sdk-utils/computer-use",
  "version": "0.0.1",
  "description": "Desktop automation tool for Anthropic computer use with the Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "lint:package": "publint",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=3.0.0"
  },
  "dependencies": {
    "@ai-sdk/provider-utils": "^4.0.23",
    "@nut-tree-fork/nut-js": "^4.2.2",
    "node-screenshots": "^0.2.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-tui/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "ai": "^6.0.68",
    "tsdown": "^0.20.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inakineitor/ai-tui.git",
    "directory": "packages/computer-use"
  },
  "keywords": [
    "ai-sdk",
    "anthropic",
    "computer-use",
    "desktop-automation",
    "screen-capture",
    "nut-js"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
